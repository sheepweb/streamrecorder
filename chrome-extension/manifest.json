{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "1.0.0",
  "description": "__MSG_extDescription__",
  "default_locale": "en",
  "permissions": [
    "cookies",
    "tabs",
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://*.livestreamrecorder.com/*",
    "https://strapi.livestreamrecorder.com/*",
    "*://*.tiktok.com/*",
    "*://*.twitch.tv/*",
    "*://*.kick.com/*",
    "*://*.youtube.com/*",
    "*://*.afreecatv.com/*",
    "*://*.sooplive.co.kr/*",
    "*://*.pandalive.co.kr/*",
    "*://*.bigo.tv/*",
    "*://*.buzzcast.com/*",
    "*://*.liveme.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
