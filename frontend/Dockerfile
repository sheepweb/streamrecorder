FROM node:22-alpine AS builder

WORKDIR /app

COPY package.json yarn.lock ./
RUN yarn install --frozen-lockfile

COPY . .

ARG NEXT_PUBLIC_PLATFORM
ARG NEXT_PUBLIC_BASE_URL
ARG NEXT_PUBLIC_FREEMIUS_PRODUCT_ID
ARG NEXT_PUBLIC_FREEMIUS_PLAN_ID
ARG NEXT_PUBLIC_FREEMIUS_PUBLIC_KEY
ARG NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY
ARG STRAPI_URL
ARG GLITCHTIP_AUTH_TOKEN
ARG GLITCHTIP_ORG
ARG GLITCHTIP_PROJECT
ARG GITHUB_SHA

ENV NEXT_PUBLIC_PLATFORM=$NEXT_PUBLIC_PLATFORM
ENV NEXT_PUBLIC_BASE_URL=$NEXT_PUBLIC_BASE_URL
ENV NEXT_PUBLIC_FREEMIUS_PRODUCT_ID=$NEXT_PUBLIC_FREEMIUS_PRODUCT_ID
ENV NEXT_PUBLIC_FREEMIUS_PLAN_ID=$NEXT_PUBLIC_FREEMIUS_PLAN_ID
ENV NEXT_PUBLIC_FREEMIUS_PUBLIC_KEY=$NEXT_PUBLIC_FREEMIUS_PUBLIC_KEY
ENV NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=$NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY
ENV STRAPI_URL=$STRAPI_URL
ENV GLITCHTIP_AUTH_TOKEN=$GLITCHTIP_AUTH_TOKEN
ENV GLITCHTIP_ORG=$GLITCHTIP_ORG
ENV GLITCHTIP_PROJECT=$GLITCHTIP_PROJECT
ENV GITHUB_SHA=$GITHUB_SHA

RUN yarn build

FROM node:22-alpine AS runner

WORKDIR /app

ENV NODE_ENV=production
ENV HOSTNAME=0.0.0.0
ENV PORT=3000

COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static
COPY --from=builder /app/public ./public

EXPOSE 3000

CMD ["node", "server.js"]
